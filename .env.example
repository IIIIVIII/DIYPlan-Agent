# Required for cloud multimodal generation.
OPENAI_API_KEY=

# Optional. Defaults are chosen for cost-aware prototyping.
OPENAI_MODEL=gpt-4.1-mini
OPENAI_STRONG_MODEL=gpt-4.1
OPENAI_ROUTER_MODEL=gpt-4.1-mini

# Local server.
PORT=5173

# Local MLX backend (Apple Silicon). The Node server calls this for the
# "Local MLX" routing strategy. Set ML_BACKEND_ENABLED=1 to always try the
# local backend first when an image is present, regardless of strategy.
ML_BACKEND_URL=http://127.0.0.1:8000
ML_BACKEND_ENABLED=0
ML_BACKEND_TIMEOUT_MS=120000
